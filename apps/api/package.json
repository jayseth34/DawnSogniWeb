{
  "name": "@dawnsogni/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "db:schema": "psql $DATABASE_URL -f apps/api/schema.sql",
    "db:setup": "node -e \"console.log('Run apps/api/schema.sql using psql.')\""
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "imagekit": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.5",
    "zod": "^4.1.5",
    "pg": "^8.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.1",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}