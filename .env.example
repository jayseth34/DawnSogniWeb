# Shared
NODE_ENV=development

# Postgres (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dawn_sogni
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
# Optional (if you prefer a single URL):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rapido_delivery

# Admin auth (no customer login)
ADMIN_PASSCODE=change-me
ADMIN_JWT_SECRET=change-me-super-secret

# CORS
WEB_ORIGIN=http://localhost:5173

# ImageKit (optional)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/vo5mye3ub

# Owner notification (MVP: stored in DB; no real sending yet)
OWNER_NOTIFY_TO=owner@example.com
